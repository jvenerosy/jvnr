{
  "name": "jvnr-site",
  "version": "1.31.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "NEXT_TELEMETRY_DISABLED=1 next build",
    "build:fast": "NEXT_TELEMETRY_DISABLED=1 NODE_ENV=production next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "analyze": "npm run build && npx @next/bundle-analyzer",
    "clean": "rm -rf .next out node_modules/.cache"
  },
  "dependencies": {
    "@types/nodemailer": "^6.4.17",
    "@types/react-google-recaptcha": "^2.1.9",
    "lucide-react": "^0.539.0",
    "next": "^16.1.6",
    "nodemailer": "^7.0.5",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-google-recaptcha": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@playwright/test": "^1.49.0",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^20.19.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "eslint": "^9",
    "eslint-config-next": "15.4.6",
    "jspdf": "^4.2.0",
    "postcss": "^8.4.49",
    "readline-sync": "^1.4.10",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^2.1.4"
  }
